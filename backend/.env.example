# ============================================================
# ZAREVIA — Backend Environment Variables (.env.example)
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
# Runtime environment: development | test | production
NODE_ENV=production

# Port the Express server will listen on (default: 5000)
PORT=5000

# Public URL of the deployed frontend (used in CORS allow-list)
FRONTEND_URL=https://your-frontend.vercel.app

# ── PostgreSQL / Prisma ───────────────────────────────────────
# Connection string to your PostgreSQL database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/zarevia_db?sslmode=require

# Optional direct URL (used by Prisma for migrations on connection-pooled setups)
# DIRECT_URL=postgresql://user:password@host:5432/zarevia_db?sslmode=require

# ── JWT Authentication ────────────────────────────────────────
# Secret for signing short-lived access tokens — use a long random string
JWT_SECRET=replace-with-at-least-32-random-characters

# Secret for signing long-lived refresh tokens — must differ from JWT_SECRET
JWT_REFRESH_SECRET=replace-with-a-different-32-random-characters

# ── Firebase Admin SDK ────────────────────────────────────────
# All of these come from your Firebase service account JSON file.
# Download: Firebase Console → Project Settings → Service Accounts → Generate new private key

# Your Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Service account client email
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Service account private key — paste the entire key, escaping newlines as \n
# On Vercel/Zeabur, paste the raw key including real newlines (no escaping needed)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# Firebase Cloud Storage bucket name (found in Firebase Console → Storage)
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ── Optional: Redis ───────────────────────────────────────────
# Connection URL for Redis (used for rate-limit store, session caching)
# Leave empty to skip Redis — the app will use in-memory fallback
# REDIS_URL=redis://localhost:6379
