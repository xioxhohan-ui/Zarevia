# ============================================================
# ZAREVIA — Frontend Environment Variables
# ============================================================
# Values extracted automatically from Firebase Service Account JSON.
# Values marked ⚠ MUST be copied from Firebase Console manually.
# ============================================================

# ── Backend API URL ───────────────────────────────────────────
# Development:
VITE_API_URL=http://localhost:5000/api
# Production (set this in Vercel/Zeabur env settings):
# VITE_API_URL=https://your-backend.zeabur.app/api

# ── Firebase Client SDK ───────────────────────────────────────
# These come from: Firebase Console → Project Settings → General → Your Apps → Web App

# ⚠ MUST get from Firebase Console → Project Settings → General → Web API Key
VITE_FIREBASE_API_KEY=

# Derived from project_id (auto-generated)
VITE_FIREBASE_AUTH_DOMAIN=zarevia.firebaseapp.com

# Extracted from service account JSON: project_id
VITE_FIREBASE_PROJECT_ID=zarevia

# Extracted from service account JSON: project_id.firebasestorage.app
VITE_FIREBASE_STORAGE_BUCKET=zarevia.firebasestorage.app

# ⚠ MUST get from Firebase Console → Project Settings → General → Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ⚠ MUST get from Firebase Console → Project Settings → General → App ID
VITE_FIREBASE_APP_ID=

# ⚠ Optional — get from Firebase Console → Project Settings → General → Measurement ID
VITE_FIREBASE_MEASUREMENT_ID=
