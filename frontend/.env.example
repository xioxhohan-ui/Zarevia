# ============================================================
# ZAREVIA — Frontend Environment Variables (.env.example)
# ============================================================
# Copy this file to .env.local and fill in your actual values.
# Only variables prefixed with VITE_ are exposed to the browser.
# NEVER put secret keys (Admin SDK, JWT secrets) in frontend env.
# ============================================================

# ── Backend API ───────────────────────────────────────────────
# Base URL of the Express backend API (no trailing slash)
# Development: http://localhost:5000/api
# Production:  https://your-backend.zeabur.app/api
VITE_API_URL=http://localhost:5000/api

# ── Firebase Client SDK ───────────────────────────────────────
# All of these come from Firebase Console → Project Settings → Your Apps → Web App → Config
# These are PUBLIC keys — safe to expose in the browser bundle.

VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
